// niri config.kdl
// Converted from hyprland.lua
// Place at: ~/.config/niri/config.kdl
// Validate with: niri validate

// ============================================================
// ENVIRONMENT VARIABLES
// ============================================================
// NOTE: For PRIME/NVIDIA hybrid setups these are critical.
// If you use niri as a systemd session (via niri-session), put
// these in ~/.config/niri/env or pass them via the session wrapper.

environment {
    XCURSOR_SIZE                 "24"
    QT_QPA_PLATFORMTHEME         "qt6ct"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    __GLX_VENDOR_LIBRARY_NAME    "mesa"
    AMD_VULKAN_ICD               "radeonsi"
    __NV_PRIME_RENDER_OFFLOAD    "0"
    LIBVA_DRIVER_NAME            "nvidia"
    ADW_DISABLE_PORTAL           "1"
    XDG_MENU_PREFIX              "arch-"
}

// ============================================================
// INPUT
// ============================================================

input {
    keyboard {
        xkb {
            layout "us"
        }
        repeat-delay 200
        repeat-rate 35
        numlock
    }


    touchpad {
        tap
        natural-scroll
    }

    mouse {
        accel-speed 0.6

    }
}


// ============================================================
// OUTPUT
// ============================================================
// Run `niri msg outputs` to find your output name (usually eDP-1 on a laptop).

output "eDP-1" {
    mode "1920x1080@60.003"
    scale 1
    transform "normal"
}

debug {
    render-drm-device "/dev/dri/renderD128"
}

// ============================================================
// LAYOUT
// ============================================================

layout {
    // gaps_in=5, gaps_out=10 in Hyprland → use 10 as the unified niri gap
    gaps 7

    center-focused-column "never"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.90
    }

    default-column-width { proportion 0.92; }

    // Focus ring replaces Hyprland's active_border / inactive_border
    focus-ring {
        width 2
        active-color   "#4c689e"
        inactive-color "#2d478c"
    }

    border {
        off
    }
}

// ============================================================
// AUTOSTART
// ============================================================

spawn-at-startup "hypridle"
spawn-at-startup "wl-paste" "--type" "text" "--watch" "cliphist" "store"
spawn-at-startup "wl-paste" "--type" "image" "--watch" "cliphist" "store"
spawn-at-startup "kbuildsycoca6"
spawn-at-startup "awww-daemon"
spawn-at-startup "dbus-update-activation-environment" "--systemd" "WAYLAND_DISPLAY" "XDG_CURRENT_DESKTOP"
spawn-at-startup "systemctl" "--user" "import-environment" "WAYLAND_DISPLAY" "XDG_CURRENT_DESKTOP"
spawn-at-startup "/usr/lib/polkit-kde-authentication-agent-1"
spawn-at-startup "noctalia"
spawn-at-startup "xwayland-satellite"
// gsettings — wrap in a shell call
spawn-at-startup "sh" "-c" "gsettings set org.gnome.desktop.interface color-scheme prefer-dark && gsettings set org.gnome.desktop.interface gtk-theme adw-gtk3"

// ============================================================
// MISC / TOP-LEVEL OPTIONS
// ============================================================

prefer-no-csd

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

hotkey-overlay {
    skip-at-startup
}

// ============================================================
// ANIMATIONS
// ============================================================
// Niri has a simpler animation system than Hyprland.
// Custom bezier curves are not supported; use spring or easing.

animations {
    slowdown 0.7

    window-open {
        duration-ms 250
        curve "ease-out-expo"
    }

    window-close {
        duration-ms 250
        curve "ease-out-expo"
    }

    horizontal-view-movement {
        duration-ms 200
        curve "ease-out-expo"
    }

    workspace-switch {
        duration-ms 200
        curve "ease-out-expo"
        }
}

// ============================================================
// BINDS
// ============================================================

binds {
    // Show hotkey overlay
    Mod+Shift+Slash { show-hotkey-overlay; }

    // Terminal
    Mod+Return { spawn "alacritty"; }

    // File manager
    Mod+E { spawn "nautilus"; }

    // App launcher (rofi)
    Mod+Space { spawn "sh" "-c" "noctalia msg panel-toggle launcher"; }

    // Control center
    Mod+S { spawn "sh" "-c" "noctalia msg panel-toggle control-center"; }

    // Settings
    Mod+Comma { spawn "sh" "-c" "noctalia msg settings-toggle"; }

    // Clipboard
    Mod+V { spawn "noctalia" "msg" "panel-toggle" "clipboard"; }

    // Exit / session
    Mod+Shift+M { quit; }

    // Lock screen
    Mod+L { spawn "sh" "-c" "noctalia msg session lock"; }

    // Toggle floating
    Mod+Shift+V { toggle-window-floating; }

    // Night light
    Mod+N { spawn "sh" "-c" "noctalia msg nightlight-enable"; }

    // Close window
    Mod+Q repeat=false { close-window; }

    // Fullscreen (F11 and Mod+Shift+F)
    Shift+F11 repeat=false { fullscreen-window; }

    // Maximize column
    Mod+F { maximize-column; }

    // ── Focus movement ──────────────────────────────────────
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-up; }
    Mod+Down  { focus-window-down; }

    // ── Move column ─────────────────────────────────────────
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+Up    { move-window-up; }
    Mod+Ctrl+Down  { move-window-down; }

    // ── Workspaces (numbered, matching Hyprland 1–9 + 0→10) ─
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+0 { focus-workspace 10; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }
    Mod+Shift+0 { move-column-to-workspace 10; }

    // ── Workspace scroll (replaces Hyprland mouse wheel workspace switch) ──
    Mod+WheelScrollDown cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp   cooldown-ms=150 { focus-workspace-up; }

    Mod+Ctrl+Comma { consume-window-into-column; }
    Mod+Ctrl+Period { expel-window-from-column; }

    // ── Column sizing ────────────────────────────────────────
    Mod+R { switch-preset-column-width; }
    Mod+Minus { set-column-width "-10%"; }
    Mod+Equal { set-column-width "+10%"; }

    // ── Column/window stacking ───────────────────────────────
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }
    Mod+Shift+W { toggle-column-tabbed-display; }

    // ── Center ───────────────────────────────────────────────
    Mod+C { center-column; }

    // ── Overview (niri's workspace overview, replaces Hyprland overview) ──
    Mod+O repeat=false { toggle-overview; }

    // ── Screenshots ──────────────────────────────────────────
    Mod+Shift+S           { spawn "sh" "-c" "noctalia msg screenshot-region ~/dotfiles/scripts/screenshot.sh output"; }
    Print           { spawn "sh" "-c" "noctalia msg screenshot-fullscreen pick"; }

    // ── Volume (via Noctalia IPC, matching original config) ──
    XF86AudioRaiseVolume  allow-when-locked=true repeat=true { spawn "sh" "-c" "noctalia msg volume-up"; }
    XF86AudioLowerVolume  allow-when-locked=true repeat=true { spawn "sh" "-c" "noctalia msg volume-down"; }
    XF86AudioMute         allow-when-locked=true             { spawn "sh" "-c" "noctalia msg volume-mute"; }

    // ── Brightness (via Noctalia IPC) ────────────────────────
    XF86MonBrightnessUp   allow-when-locked=true repeat=true { spawn "sh" "-c" "noctalia msg brightness-up"; }
    XF86MonBrightnessDown allow-when-locked=true repeat=true { spawn "sh" "-c" "noctalia msg brightness-down"; }

    // ── Touchpad & Numlock ───────────────────────────────────
    XF86TouchpadOn  allow-when-locked=true { spawn "sh" "-c" "bash ~/dotfiles/scripts/touchpad.sh on"; }
    XF86TouchpadOff allow-when-locked=true { spawn "sh" "-c" "bash ~/dotfiles/scripts/touchpad.sh off"; }
    Num_Lock        allow-when-locked=true { spawn "sh" "-c" "bash ~/dotfiles/scripts/numlock.sh"; }

    // ── Media keys ───────────────────────────────────────────
    XF86AudioNext  allow-when-locked=true { spawn "playerctl" "next"; }
    XF86AudioPause allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPlay  allow-when-locked=true { spawn "playerctl" "play-pause"; }
    XF86AudioPrev  allow-when-locked=true { spawn "playerctl" "previous"; }
}

// ============================================================
// WINDOW RULES
// ============================================================

// alacritty: floating, centered, with opacity


// Firefox PiP — always floating
window-rule {
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    open-floating true
}
window-rule {
    geometry-corner-radius 18
    clip-to-geometry true
}

include "noctalia.kdl"
